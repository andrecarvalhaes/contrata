# API Configuration
# NEXT_PUBLIC_API_URL=https://api.nexto.com

# AI Chat Configuration
# Escolha um dos serviços abaixo (descomente o que for usar)

# Claude API (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API
# OPENAI_API_KEY=sk-xxxxx

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase (substitui o Firebase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Service role só em ambientes server-side / Edge Functions (NUNCA expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# Conekta Payment Configuration
CONEKTA_PRIVATE_KEY=key_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=key_xxxxxxxxxxxxxxxxxxxxx

# Email Service (para integração futura)
# EMAIL_SERVICE_API_KEY=

# Analytics (para integração futura)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_MIXPANEL_TOKEN=
